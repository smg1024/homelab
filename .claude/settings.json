{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "fable",
  "effortLevel": "xhigh",
  "statusLine": {
    "type": "command",
    "command": "bun \"$CLAUDE_PROJECT_DIR/.agents/hooks/hud.ts\""
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "WebSearch",
      "Bash(nix flake check:*)",
      "Bash(nix flake show:*)",
      "Bash(nix flake metadata:*)",
      "Bash(nix fmt:*)",
      "Bash(nix eval:*)",
      "Bash(just --list)",
      "Bash(just default)",
      "Bash(gh:*)",
      "Bash(just test:*)"
    ],
    "ask": [
      "Bash(just switch:*)",
      "Bash(nixos-rebuild:*)",
      "Bash(nix flake update:*)",
      "Bash(ssh:*)"
    ],
    "deny": [
      "Read(./secrets/**)",
      "Read(./**/*.env)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "env": {
    "cleanupPeriodDays": 180,
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": 100000,
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": 80
  },
  "skipDangerousModePermissionPrompt": true
}
